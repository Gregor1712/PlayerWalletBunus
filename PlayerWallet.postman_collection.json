      "name": "1. Registration",
      "item": [
        {
          "name": "Register wallet (201 Created)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('Returned playerId matches', () => pm.expect(body.playerId).to.eql(pm.collectionVariables.get('playerId')));",
                  "pm.test('Initial balance is 0', () => pm.expect(body.balance).to.eql(0));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/players/{{playerId}}/wallet",
              "host": ["{{baseUrl}}"],
              "path": ["api", "players", "{{playerId}}", "wallet"]
            }
          }
        },
        {
          "name": "Register wallet — duplicate (409 Conflict)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('Error message present', () => pm.expect(pm.response.json().error).to.include('already registered'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/players/{{playerId}}/wallet",
              "host": ["{{baseUrl}}"],
              "path": ["api", "players", "{{playerId}}", "wallet"]
